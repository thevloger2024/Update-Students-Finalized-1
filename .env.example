# ─────────────────────────────────────────────────────────────
# REQUIRED
# ─────────────────────────────────────────────────────────────

# Gemini AI API Key — Required for ALL AI features
# Get it from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# App URL — Auto-injected by AI Studio / Cloud Run
APP_URL="http://localhost:3000"

# ─────────────────────────────────────────────────────────────
# OPTIONAL — Email Alerts (Feature 6D: Error Detection)
# ─────────────────────────────────────────────────────────────

# Gmail SMTP settings for error alert emails
# To get App Password: Google Account → Security → 2-Step Verification → App Passwords
SMTP_HOST="smtp.gmail.com"
SMTP_USER="thevloger2024@gmail.com"
SMTP_PASS="YOUR_GMAIL_APP_PASSWORD_HERE"

# Admin email where alerts will be sent
ADMIN_EMAIL="thevloger2024@gmail.com"

# ─────────────────────────────────────────────────────────────
# OPTIONAL — Google Custom Search API (Feature 6E: Trending Topics)
# ─────────────────────────────────────────────────────────────

# Get Search API Key: https://developers.google.com/custom-search/v1/introduction
# Create Search Engine: https://programmablesearchengine.google.com/
GOOGLE_SEARCH_API_KEY="YOUR_GOOGLE_SEARCH_API_KEY_HERE"
GOOGLE_SEARCH_ENGINE_ID="YOUR_CUSTOM_SEARCH_ENGINE_ID_HERE"

# ─────────────────────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
